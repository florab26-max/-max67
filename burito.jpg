	<script type="application/ld+json" class="yoast-schema-graph">{"@context":"https://schema.org","@graph":[{"@type":"Article","@id":"https://villacocina.com/burrito-supremo/#article","isPartOf":{"@id":"https://villacocina.com/burrito-supremo/"},"author":{"name":"Villa Cocina","@id":"https://villacocina.com/#/schema/person/cef24addc0419b05cde1a30f85a66943"},"headline":"Burrito Supremo","datePublished":"2023-06-16T22:44:40+00:00","dateModified":"2025-09-02T01:10:55+00:00","wordCount":889,"commentCount":4,"publisher":{"@id":"https://villacocina.com/#organization"},"image":{"@id":"https://villacocina.com/burrito-supremo/#primaryimage"},"thumbnailUrl":"https://villacocina.com/wp-content/uploads/2023/06/Burrito-Supremo-WEBSITE--scaled.jpg","keywords":["Burrito Supremo","burritos","Delicious","Easy recipes","Food","foodie","Mexican food","Mexican recipes","Villa Cocina","Yummy"],"articleSection":["Main Dish"],"inLanguage":"en","potentialAction":[{"@type":"CommentAction","name":"Comment","target":["https://villacocina.com/burrito-supremo/#respond"]}]},{"@type":"WebPage","@id":"https://villacocina.com/burrito-supremo/","url":"https://villacocina.com/burrito-supremo/","name":"Burrito Supremo - Villa Cocina","isPartOf":{"@id":"https://villacocina.com/#website"},"primaryImageOfPage":{"@id":"https://villacocina.com/burrito-supremo/#primaryimage"},"image":{"@id":"https://villacocina.com/burrito-supremo/#primaryimage"},"thumbnailUrl":"https://villacocina.com/wp-content/uploads/2023/06/Burrito-Supremo-WEBSITE--scaled.jpg","datePublished":"2023-06-16T22:44:40+00:00","dateModified":"2025-09-02T01:10:55+00:00","description":"Burrito Supremo is ‘supreme’ in flavor—indulgent, packed with taste, and even better when made at home with love.","breadcrumb":{"@id":"https://villacocina.com/burrito-supremo/#breadcrumb"},"inLanguage":"en","potentialAction":[{"@type":"ReadAction","target":["https://villacocina.com/burrito-supremo/"]}]},{"@type":"ImageObject","inLanguage":"en","@id":"https://villacocina.com/burrito-supremo/#primaryimage","url":"https://villacocina.com/wp-content/uploads/2023/06/Burrito-Supremo-WEBSITE--scaled.jpg","contentUrl":"https://villacocina.com/wp-content/uploads/2023/06/Burrito-Supremo-WEBSITE--scaled.jpg","width":2560,"height":1707,"caption":"Burrito Supremo"},{"@type":"BreadcrumbList","@id":"https://villacocina.com/burrito-supremo/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://villacocina.com/"},{"@type":"ListItem","position":2,"name":"Recipes","item":"https://villacocina.com/recipes/"},{"@type":"ListItem","position":3,"name":"Main Dish","item":"https://villacocina.com/newcat/main-dish/"},{"@type":"ListItem","position":4,"name":"Burrito Supremo"}]},{"@type":"WebSite","@id":"https://villacocina.com/#website","url":"https://villacocina.com/","name":"Villa Cocina","description":"Mouthwatering and Authentic Mexican Cuisine","publisher":{"@id":"https://villacocina.com/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://villacocina.com/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en"},{"@type":"Organization","@id":"https://villacocina.com/#organization","name":"Villa Cocina","url":"https://villacocina.com/","logo":{"@type":"ImageObject","inLanguage":"en","@id":"https://villacocina.com/#/schema/logo/image/","url":"https://villacocina.com/wp-content/uploads/2024/03/1x1-trial-1.jpg","contentUrl":"https://villacocina.com/wp-content/uploads/2024/03/1x1-trial-1.jpg","width":1081,"height":1080,"caption":"Villa Cocina"},"image":{"@id":"https://villacocina.com/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/villacocinaofficial","https://x.com/villa_cocina","https://www.instagram.com/villacocinaofficial/","https://www.pinterest.com/villacocina/","https://www.tiktok.com/@villacocina?lang=en","https://www.youtube.com/c/VillaCocina"],"description":"Villa Cocina is a food blog that focuses on Mexican cuisine. Our goal is to bring Mexico to everyone's table through our recipes."},{"@type":"Person","@id":"https://villacocina.com/#/schema/person/cef24addc0419b05cde1a30f85a66943","name":"Villa Cocina","sameAs":["https://villacocina.com/about-us/"],"url":"https://villacocina.com/author/rossana/"},{"@type":"Recipe","name":"Burrito Supremo","author":{"@id":"https://villacocina.com/#/schema/person/cef24addc0419b05cde1a30f85a66943"},"description":"Burrito Supremo—‘Supreme’ in name and flavor. This indulgent, flavor-packed style catches the eye on any restaurant menu, but when made at home, it’s even better.","datePublished":"2023-06-16T22:44:40+00:00","image":["https://villacocina.com/wp-content/uploads/2023/06/Burrito-Supremo-WEBSITE--scaled.jpg"],"video":{"name":"How to make a BURRITO SUPREMO | Easy BURRITO Bowl | Villa Cocina","description":"#food #mexicanfood #burrito \nEasy to make burrito supremo. It's loaded with fresh, deep flavors. And, dressed with a smoky, creamy chipotle sauce. So much to love! Find link to recipe below ⤵️⤵️⤵️⤵️⤵️⤵️⤵️⤵️⤵️⤵️⤵️⤵️⤵️\n\n🖨️ FULL PRINTABLE recipe here 👉🏻 https://villacocina.com/burrito-supremo/\n\n☞ Feel free to visit my YOUTUBE page for alot more recipes: \nhttps://www.youtube.com/c/VillaCocina\n\nBurrito Supremo Recipe \n(As an Amazon Associate I earn from qualifying purchases)\n\n➤ Cilantro lime rice\n2 TBSP olive oil, smooth : https://amzn.to/3OeY04J\n1 cup long grain rice : https://amzn.to/3UAaC9Q\n1/2 medium yellow onion\n2 cups water\n1 tsp kosher salt : https://amzn.to/3e5Lm7k\n1 ea lime zested\n2 TBSP lime juice \n1/2 cup cilantro, chopped \n\n➤ Beans \n3 cups cooked black beans \n** with some of the cooking liquid \n1/2 medium yellow onion\n3 ea garlic cloves\n3 TBSP olive oil, smooth\nSalt to taste (1/4 tsp)\n\n➤ Chipotle Sauce\n1 cup sour cream\n1/4 cup mayo : https://amzn.to/3NfRz07\n2 ea chipotle peppers in adobo : https://amzn.to/3JiH1x9\n1 TBSP lime juice (1/2 lime)\n1 ea garlic clove\nSalt to taste (1 tsp salt kosher)\n\n➤ Ground beef \n2 TBSP olive oil, smooth\n1 lb ground beef\n2 tsp ancho chile, ground : https://amzn.to/3CuQAE9\n2 tsp paprika, smoked : https://amzn.to/3GPY1IQ\n2 tsp ground onion : https://amzn.to/3xf7TZh\n2 tsp ground garlic : https://amzn.to/3GKiSwW\n1/2 tsp ground cumin : https://amzn.to/3CA3xN6\n1 tsp kosher salt\n1 cup beef broth, low sodium : https://amzn.to/46aefZl\n\nPico de Gallo\n🖨️ Print: https://villacocina.com/pico-de-gallo-mexican-salsa/\n🎥 Video: https://youtu.be/EP52GIYq6Lk\n1 ea avocado, diced \n\nShredded oaxaca cheese \nShredded lettuce \n4-6 ea flour tortillas, extra large \n\n🌟PRODUCTS IN THIS VIDEO 🛒\n(As an Amazon Associate I earn from qualifying purchases)\n➤ Staub Cast Iron with lid 3.5 qt: https://amzn.to/3vJobba\n➤ Zwilling CLAD CFX 4.5-qt non-stick pan: https://amzn.to/3oZRSFu\n➤ Le Creuset Stainless Steel Fry Pan  12”:  https://amzn.to/3eadQeP\n➤ Vitamix A3500 Smart blender Professional grade 64oz : https://amzn.to/2JMeSml\n➤ Vitamix Blending Cup and Bowl Starter Kit for Vitamix Ascent and Venturist machines: https://amzn.to/3GptIs1\n➤ Shun Classic 8” Chef’s Knife All-Purpose Blade, Curved Blade for Easy Cuts; Cutlery Handcrafted in Japan: https://amzn.to/35AAqKm\n➤ Cooking Light Potato Masher : https://amzn.to/3EQE0zh\n➤ Allspice wood spice rack, 30 jars: https://amzn.to/3nyUmd8\n➤ Henckels Cooking tools 6 pc set : https://amzn.to/3N9WtNf\n➤ Microplane Classic Zester/Grater Black : https://amzn.to/39Ls9Vc\n➤ Pyrex glass bowl set of 3 : https://amzn.to/2NyauWx\n➤ OXO 6-inch fine mesh strainer: https://amzn.to/3h1pDNs\n\n🛒 For products I have in my kitchen click the link below 👇🏻\nhttps://www.amazon.com/shop/villacocina\n\n☞ Email for business inquiries only: \n     rossana@villacocina.com\n\n💌 Fan mail: \nVilla Cocina \nP.O. Box 309\nTucker, GA 30085\nUSA\n\nFollow me on all Social media platforms: 👇🏻\n❤️ English youtube channel: https://www.youtube.com/c/VillaCocina\n💜 Instagram: https://www.instagram.com/villacocinaofficial/\n💙 Facebook: https://www.facebook.com/villacocinaofficial\n❤️ Pintrest : https://www.pinterest.com/villacocina/\n💙 Twitter: https://twitter.com/villa_cocina\n🖤 TikTok: https://www.tiktok.com/@villacocina?lang=en\n\nCopyright © 2023 Villa cocina","uploadDate":"2023-06-16T23:00:03+00:00","duration":"PT7M50S","thumbnailUrl":"https://i.ytimg.com/vi/5nsuctc9NEk/hqdefault.jpg","embedUrl":"https://www.youtube.com/embed/5nsuctc9NEk?feature=oembed","contentUrl":"https://www.youtube.com/watch?v=5nsuctc9NEk","@type":"VideoObject"},"recipeYield":["5","5 burritos"],"prepTime":"PT25M","cookTime":"PT40M","totalTime":"PT65M","recipeIngredient":["2 tbsp olive oil (smooth)","1 cup white long grain rice ","1/2  yellow onion (diced)","2 cups water","1 tsp kosher salt (or to taste )","1  lime (zested)","2 tbsp lime juice","1/2 cup cilantro (chopped )","3 cups cooked black beans","1 cup bean broth","1/2  yellow onion (diced)","3  garlic cloves (minced)","3 tbsp olive oil (smooth)","To taste salt","1 cup sour cream","1/4 cup mayonnaise","2  chipotle peppers in adobo","1 tbsp lime juice ","1  garlic clove (peeled)","To taste salt ((1 tsp kosher salt))","2 tbsp olive oil (smooth)","1 lb ground beef","2 tsp ground ancho chile","2 tsp smoked paprika","2 tsp ground onion ","2 tsp ground garlic ","1/2 tsp ground cumin ","To taste kosher salt ((1 tsp))","1 cup beef broth (low sodium)","Oaxaca or mozzarella cheese  (grated)","Lettuce (shredded)","5  flour tortillas (extra large)","Pico de gallo","1  avocado (diced)"],"recipeInstructions":[{"@type":"HowToSection","name":"Cook the Rice","itemListElement":[{"@type":"HowToStep","text":"Rinse the rice under water until the water runs clear. Heat the oil in a medium pot over medium-high heat, then add the drained rice and diced onion. Sauté until fragrant, about 3 minutes. ","name":"Rinse the rice under water until the water runs clear. Heat the oil in a medium pot over medium-high heat, then add the drained rice and diced onion. Sauté until fragrant, about 3 minutes. ","url":"https://villacocina.com/burrito-supremo/#wprm-recipe-7828-step-0-0"},{"@type":"HowToStep","text":"Pour in the water and add salt. Bring to a boil, then reduce the heat to medium-low and cover. Let it simmer gently until the water is absorbed and the rice is tender but not mushy. ","name":"Pour in the water and add salt. Bring to a boil, then reduce the heat to medium-low and cover. Let it simmer gently until the water is absorbed and the rice is tender but not mushy. ","url":"https://villacocina.com/burrito-supremo/#wprm-recipe-7828-step-0-1"},{"@type":"HowToStep","text":"Remove from heat and let the rice rest, covered, for 10 minutes. Stir in lime zest, lime juice, and cilantro, then set aside. ","name":"Remove from heat and let the rice rest, covered, for 10 minutes. Stir in lime zest, lime juice, and cilantro, then set aside. ","url":"https://villacocina.com/burrito-supremo/#wprm-recipe-7828-step-0-2"}]},{"@type":"HowToSection","name":"Prepare the Beans","itemListElement":[{"@type":"HowToStep","text":"Heat oil in a large pan over medium heat. Sauté the onions until golden brown, then add the garlic and cook for 1–2 minutes until fragrant. ","name":"Heat oil in a large pan over medium heat. Sauté the onions until golden brown, then add the garlic and cook for 1–2 minutes until fragrant. ","url":"https://villacocina.com/burrito-supremo/#wprm-recipe-7828-step-1-0"},{"@type":"HowToStep","text":"Pour in the cooked beans along with about 1 cup of their cooking liquid, stirring as you cook until the liquid thickens and coats the beans. Season with salt to taste and keep covered off the heat until ready to use. ","name":"Pour in the cooked beans along with about 1 cup of their cooking liquid, stirring as you cook until the liquid thickens and coats the beans. Season with salt to taste and keep covered off the heat until ready to use. ","url":"https://villacocina.com/burrito-supremo/#wprm-recipe-7828-step-1-1"}]},{"@type":"HowToSection","name":"Chipotle Sauce","itemListElement":[{"@type":"HowToStep","text":"Combine all the sauce ingredients in a blender and process until smooth. Transfer the sauce into a container, cover, and refrigerate until ready to use.","name":"Combine all the sauce ingredients in a blender and process until smooth. Transfer the sauce into a container, cover, and refrigerate until ready to use.","url":"https://villacocina.com/burrito-supremo/#wprm-recipe-7828-step-2-0"}]},{"@type":"HowToSection","name":"Beef Filling","itemListElement":[{"@type":"HowToStep","text":"Heat a large pan over medium-high heat and add the oil, then the ground beef. Press the meat evenly with a potato masher so it spreads across the pan. Let the underside brown, then break it apart. ","name":"Heat a large pan over medium-high heat and add the oil, then the ground beef. Press the meat evenly with a potato masher so it spreads across the pan. Let the underside brown, then break it apart. ","url":"https://villacocina.com/burrito-supremo/#wprm-recipe-7828-step-3-0"},{"@type":"HowToStep","text":"Add ancho chile, paprika, ground onion, ground garlic, cumin, and salt, stirring to combine evenly. ","name":"Add ancho chile, paprika, ground onion, ground garlic, cumin, and salt, stirring to combine evenly. ","url":"https://villacocina.com/burrito-supremo/#wprm-recipe-7828-step-3-1"},{"@type":"HowToStep","text":"Once the meat is fully cooked, pour in the broth and cook until it reduces almost completely, keeping the meat moist. Remove from heat and keep covered. ","name":"Once the meat is fully cooked, pour in the broth and cook until it reduces almost completely, keeping the meat moist. Remove from heat and keep covered. ","url":"https://villacocina.com/burrito-supremo/#wprm-recipe-7828-step-3-2"}]},{"@type":"HowToSection","name":"Make Pico de Gallo","itemListElement":[{"@type":"HowToStep","text":"Prepare the pico de gallo and fold in the avocado. Keep covered.","name":"Prepare the pico de gallo and fold in the avocado. Keep covered.","url":"https://villacocina.com/burrito-supremo/#wprm-recipe-7828-step-4-0"}]},{"@type":"HowToSection","name":"Assemble the Burrito","itemListElement":[{"@type":"HowToStep","text":"Heat an extra large flour tortilla until flexible. Layer rice, beans, ground beef, pico de gallo, cheese, lettuce, and chipotle sauce in the center of the tortilla. ","name":"Heat an extra large flour tortilla until flexible. Layer rice, beans, ground beef, pico de gallo, cheese, lettuce, and chipotle sauce in the center of the tortilla. ","url":"https://villacocina.com/burrito-supremo/#wprm-recipe-7828-step-5-0"},{"@type":"HowToStep","text":"Fold the sides in toward the middle to keep the filling from falling out. Next, fold the bottom edge over the filling and roll the tortilla tightly. Fold any leftover side flaps inward and continue rolling until the burrito is fully wrapped, seam-side down to secure it.","name":"Fold the sides in toward the middle to keep the filling from falling out. Next, fold the bottom edge over the filling and roll the tortilla tightly. Fold any leftover side flaps inward and continue rolling until the burrito is fully wrapped, seam-side down to secure it.","url":"https://villacocina.com/burrito-supremo/#wprm-recipe-7828-step-5-1"},{"@type":"HowToStep","text":"Cut the burrito in half and serve with a side of chipotle sauce for dipping.","name":"Cut the burrito in half and serve with a side of chipotle sauce for dipping.","url":"https://villacocina.com/burrito-supremo/#wprm-recipe-7828-step-5-2"}]}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"13","reviewCount":"2"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Everything about this was amazing. We thought it was as good if not better than what we get at our local restaurant. Thanks so much for sharing this. Also, this will be our new go-to taco seasoning. So good.","author":{"@type":"Person","name":"Steve"},"datePublished":"2025-05-24"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Very delicious! My sister suggested your recipe and we both enjoyed the burritos with that smokey sauce sauce so much my sister said, \"It's so hard to say good-bye\" when they were eaten entirely. Thank you for your recipes!","author":{"@type":"Person","name":"Tanica"},"datePublished":"2024-12-25"}],"recipeCategory":["Main"],"recipeCuisine":["Mexican"],"keywords":"Burrito, Burrito Supremo, Mexican Food","nutrition":{"@type":"NutritionInformation","calories":"1037 kcal","servingSize":"1 burrito","carbohydrateContent":"83 g","proteinContent":"34 g","fatContent":"65 g","saturatedFatContent":"18 g","transFatContent":"1 g","cholesterolContent":"96 mg","sodiumContent":"1039 mg","fiberContent":"15 g","sugarContent":"5 g","unsaturatedFatContent":"41 g"},"@id":"https://villacocina.com/burrito-supremo/#recipe","isPartOf":{"@id":"https://villacocina.com/burrito-supremo/#article"},"mainEntityOfPage":"https://villacocina.com/burrito-supremo/"}]}</script>
