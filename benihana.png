44d8-9912-26ecb0dd8d31-1720928279878-0.jpeg" alt="Benihana photo 17" class="h-56 w-auto object-cover flex-shrink-0"/></div></div><p class="text-sm text-gray-700 font-[family-name:var(--font-chivo)] leading-relaxed mb-6">Watch skilled cooks flip shrimp and juggle utensils while preparing your hibachi feast. Perfect for a fun night out or group dinner. Don&#x27;t miss the fried rice.</p><div class="mb-8 border border-black overflow-hidden hover:bg-[#FBFFA6] transition-colors"><p class="text-xs text-gray-600 uppercase font-[family-name:var(--font-clash-grotesk)] font-semibold px-4 pt-4 pb-3">SAVED ON CORNER BY</p><div class="overflow-x-auto scrollbar-hide pb-4"><div class="flex gap-4 whitespace-nowrap px-4"><a href="https://www.corner.inc/ary3" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity flex-shrink-0"><img src="https://cdn.corner.inc/profiles/951b31dd-327c-4ea6-8d00-374835a2e6af-1765895162518.jpeg" alt="ary3" class="w-20 h-24 rounded-full object-cover"/><span class="text-xs font-[family-name:var(--font-clash-grotesk)] font-medium w-20 text-center overflow-hidden text-ellipsis uppercase">ary3</span></a><a href="https://www.corner.inc/theo_wmr" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity flex-shrink-0"><img src="https://cdn.corner.inc/profiles/c274fbba-a904-4773-8223-72bbf63a8ade-1770802273471.jpeg" alt="theo_wmr" class="w-20 h-24 rounded-full object-cover"/><span class="text-xs font-[family-name:var(--font-clash-grotesk)] font-medium w-20 text-center overflow-hidden text-ellipsis uppercase">theo_wmr</span></a><a href="https://www.corner.inc/giak" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity flex-shrink-0"><img src="https://cdn.corner.inc/profiles/4dfb2691-dcce-4f0d-aaa1-ea2e87bad761-1768794452612.jpeg" alt="giak" class="w-20 h-24 rounded-full object-cover"/><span class="text-xs font-[family-name:var(--font-clash-grotesk)] font-medium w-20 text-center overflow-hidden text-ellipsis uppercase">giak</span></a><a href="https://www.corner.inc/pocahontas" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity flex-shrink-0"><img src="https://cdn.corner.inc/profiles/0ebd3d44-fec9-46b7-80bb-f2900a93e2b4-1741585633189.jpeg" alt="pocahontas" class="w-20 h-24 rounded-full object-cover"/><span class="text-xs font-[family-name:var(--font-clash-grotesk)] font-medium w-20 text-center overflow-hidden text-ellipsis uppercase">pocahontas</span></a><a href="https://www.corner.inc/cece_0914" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity flex-shrink-0"><img src="https://cdn.corner.inc/profiles/ac69ce26-ea48-4db8-ab78-6d72b125f61a-1762094848060.jpeg" alt="cece_0914" class="w-20 h-24 rounded-full object-cover"/><span class="text-xs font-[family-name:var(--font-clash-grotesk)] font-medium w-20 text-center overflow-hidden text-ellipsis uppercase">cece_0914</span></a><a href="https://www.corner.inc/julez" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity flex-shrink-0"><img src="https://cdn.corner.inc/profiles/6d283ae0-06eb-448b-968e-c08244d03ed6-1752469148886.jpeg" alt="julez" class="w-20 h-24 rounded-full object-cover"/><span class="text-xs font-[family-name:var(--font-clash-grotesk)] font-medium w-20 text-center overflow-hidden text-ellipsis uppercase">julez</span></a><a href="https://www.corner.inc/brandon.0" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity flex-shrink-0"><img src="https://cdn.corner.inc/profiles/3818234a-8a41-4403-a5c3-e47d9de2db2d-1756930418472.jpeg" alt="brandon.0" class="w-20 h-24 rounded-full object-cover"/><span class="text-xs font-[family-name:var(--font-clash-grotesk)] font-medium w-20 text-center overflow-hidden text-ellipsis uppercase">brandon.0</span></a><a href="https://www.corner.inc/seanzhang" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity flex-shrink-0"><img src="https://cdn.corner.inc/profiles/50a406ae-7b53-41b8-92da-0febd495897f-1743256981649.jpeg" alt="seanzhang" class="w-20 h-24 rounded-full object-cover"/><span class="text-xs font-[family-name:var(--font-clash-grotesk)] font-medium w-20 text-center overflow-hidden text-ellipsis uppercase">seanzhang</span></a><a href="https://www.corner.inc/ekbergmann" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity flex-shrink-0"><img src="https://cdn.corner.inc/profiles/a907e51f-7dc8-41f7-9d15-8ae0ca0e67e2-1753229676256.jpeg" alt="ekbergmann" class="w-20 h-24 rounded-full object-cover"/><span class="text-xs font-[family-name:var(--font-clash-grotesk)] font-medium w-20 text-center overflow-hidden text-ellipsis uppercase">ekbergmann</span></a><a href="https://www.corner.inc/riyakohli" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-1 hover:opacity-80 transition-opacity flex-shrink-0"><img src="https://cdn.corner.inc/profiles/e189de00-8998-44d8-9912-26ecb0dd8d31-1730675375074.jpeg" alt="riyakohli" class="w-20 h-24 rounded-full object-cover"/><span class="text-xs font-[family-name:var(--font-clash-grotesk)] font-medium w-20 text-center overflow-hidden text-ellipsis uppercase">riyakohli</span></a></div></div></div><section class="mb-8"><div class="border border-black p-4 bg-white"><div class="space-y-4"><div><h3 class="text-[18px] font-[family-name:var(--font-clash-display)] font-semibold uppercase mb-2 text-black">VIBE</h3><p class="text-black text-sm leading-relaxed font-[family-name:var(--font-chivo)]">Teppanyaki theater where chefs flip shrimp into their hats and set onions on fire. Communal tables mean you&#x27;re dining with strangers who cheer when someone catches rice in their mouth.</p></div><div><h3 class="text-[18px] font-[family-name:var(--font-clash-display)] font-semibold uppercase mb-2 text-black">WHAT TO GET</h3><p class="text-black text-sm leading-relaxed font-[family-name:var(--font-chivo)]">Whatever protein your chef recommends, and lean into the fried rice finale.</p></div><div><h3 class="text-[18px] font-[family-name:var(--font-clash-display)] font-semibold uppercase mb-2 text-black">THE MOVE</h3><p class="text-black text-sm leading-relaxed font-[family-name:var(--font-chivo)]">Go for the show, not the sushi. Your clothes will smell like hibachi smoke for days.</p></div><div><h3 class="text-[18px] font-[family-name:var(--font-clash-display)] font-semibold uppercase mb-2 text-black">BEST FOR</h3><p class="text-black text-sm leading-relaxed font-[family-name:var(--font-chivo)]">Birthdays, first dates where you need built-in entertainment, or when you want dinner and a performance in one.</p></div></div></div></section><section class="mb-8"><h2 class="text-lg font-[family-name:var(--font-clash-display)] font-semibold uppercase mb-4">What people are saying</h2><div class="space-y-6"><div class="space-y-3"><div class="flex pl-[56px]"><div class="flex flex-col gap-2"><div class="flex flex-grow w-2/3 relative" style="height:233px"><div class="select-none border-2 border-transparent [-webkit-tap-highlight-color:transparent] cursor-pointer" style="height:233px;aspect-ratio:4/5;position:relative;opacity:1;z-index:2;transform:none"><img alt="Image" loading="lazy" decoding="async" data-nimg="fill" class="object-cover rounded-xl shadow-xl pointer-events-none select-none" style="position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent" src="https://cdn.corner.inc/ugc/951b31dd-327c-4ea6-8d00-374835a2e6af-1769720545934-0.jpeg"/></div><div class="select-none border-2 border-transparent [-webkit-tap-highlight-color:trans