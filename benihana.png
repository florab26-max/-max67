tions\"},{\"id\":\"9ff9be7b-0014-4839-a950-feefbe57c94e\",\"media_url\":\"https://cdn.corner.inc/place-photo/AUc7tXWpe_1JpnNsY6fktf6j9DtSBEN7b7I1CQ34rb36SkQqrEaVJuo8n36xtSuP8Ef4K8C8jYcO7tqi1rZ7y6lkpfltbLbxlRvBIBTllyYHgfE_wHZYgQTFZbVeHxP0ie_ioQTbgmuD6osruxGBBTyhZZ0foB5dT01Z-IVP0SaqnE-keQ7W.png\",\"category\":\"food\",\"confidence\":\"0.9994338154792786\",\"rank\":16,\"section\":\"recommendations\"},{\"id\":\"0a8791a7-753b-41cb-a0ab-edf3732c15aa\",\"media_url\":\"https://cdn.corner.inc/ugc/e189de00-8998-44d8-9912-26ecb0dd8d31-1720928279878-0.jpeg\",\"category\":\"food\",\"confidence\":\"0.9988434314727783\",\"rank\":17,\"section\":\"recommendations\"}],\"crowd\":[{\"id\":\"a663cc58-674d-45a2-8c5f-bc31a6fb9a26\",\"media_url\":\"https://cdn.corner.inc/ugc/e189de00-8998-44d8-9912-26ecb0dd8d31-1720928279878-1.jpeg\",\"category\":\"people\",\"confidence\":\"0.828457772731781\",\"rank\":8,\"section\":\"crowd\"}],\"the_space\":[]},\"editorialSections\":{\"vibe\":\"Teppanyaki theater where chefs flip shrimp into their hats and set onions on fire. Communal tables mean you're dining with strangers who cheer when someone catches rice in their mouth.\",\"the_move\":\"Go for the show, not the sushi. Your clothes will smell like hibachi smoke for days.\",\"best_for\":\"Birthdays, first dates where you need built-in entertainment, or when you want dinner and a performance in one.\",\"recommendations\":\"Whatever protein your chef recommends, and lean into the fried rice finale.\"}}}],[\"$\",\"$L23\",null,{\"contentGroups\":[{\"user\":{\"id\":\"951b31dd-327c-4ea6-8d00-374835a2e6af\",\"name\":\"ary\",\"username\":\"ary3\",\"profilePictureUrl\":\"https://cdn.corner.inc/profiles/951b31dd-327c-4ea6-8d00-374835a2e6af-1765895162518.jpeg\"},\"posts\":[{\"id\":\"6577d0cd-26e2-49ad-8819-8c134b783929\",\"caption\":\"went for happy hour! sushi \u0026 hibachi were okay lol\",\"status\":\"okay\",\"createdAt\":\"2026-01-29T21:02:25.068Z\",\"lists\":[],\"commentCount\":\"0\",\"link\":null,\"threadI